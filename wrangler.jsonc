{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "polyproxy",
	"main": "src/worker.tsx",
	"compatibility_date": "2026-05-22",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": "./public"
	},
	"kv_namespaces": [
		{
			"binding": "OBSIDIAN_QUERIES"
		}
	],
	"observability": {
		"enabled": true
	},
	"vars": {
		"PUBLIC_BASE_URL": "https://open.axross.dev"
	}
}
